    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": ["react","nextjs","chat","widget","webrtc","support","tickets","drawer","typescript"],
